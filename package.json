{
  "name": "workout-bot",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply workout-bot --local",
    "db:migrate:prod": "wrangler d1 migrations apply workout-bot --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.4.0"
  }
}